{
  "name": "@synapse/cli",
  "version": "0.1.0",
  "private": false,
  "type": "commonjs",
  "bin": {
    "synapse": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "publish:check": "npm run build && npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
